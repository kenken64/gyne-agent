REDIS_URL=redis://127.0.0.1/
TASK_STREAM=openclaw:tasks
RESULT_STREAM=openclaw:results
CONSUMER_REGISTRY_KEY=openclaw:consumers

PUBLISHER_BIND=127.0.0.1:8080
DEFAULT_MODEL=openclaw-chat

CONSUMER_GROUP=openclaw-workers
CONSUMER_NAME=consumer-1
CONSUMER_TASK_STREAM=openclaw:tasks:consumer-1
CONSUMER_DISCOVERY_TTL_MS=15000
CONSUMER_HEARTBEAT_INTERVAL_MS=5000
CONSUMER_STALE_AFTER_MS=15000
REDIS_BLOCK_MS=5000
REDIS_READ_COUNT=1

OPENCLAW_BASE_URL=https://api.openclaw.ai/v1
OPENCLAW_CHAT_COMPLETIONS_URL=https://api.openclaw.ai/v1/chat/completions
OPENCLAW_GATEWAY_TOKEN=replace-me
OPENCLAW_GATEWAY_TOKEN_HEADER=Authorization

VITE_PUBLISHER_WS_URL=ws://127.0.0.1:8080/ws
VITE_DEFAULT_MODEL=openclaw-chat
